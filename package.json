{
    "name": "@bbp/morphoviewer",
    "version": "0.24.4",
    "description": "Class to display SWC morphology files in 3D",
    "main": "./lib/dist/index.js",
    "module": "./lib/dist/index.js",
    "types": "./lib/dist",
    "files": [
        "./lib/dist"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/BlueBrain/morphoviewer.git"
    },
    "keywords": [
        "SWC",
        "morphology",
        "BBP",
        "OBI",
        "webgl2"
    ],
    "scripts": {
        "clean": "rm -rf dist node_modules package-lock.json lib/node_modules lib/package-lock.json doc/node_modules doc/package-lock.json && npm run version",
        "prebuild": "npm run version",
        "build": "cd lib && npm install && npm run build && cd .. && npm pack",
        "minor": "npm version minor -no-git-tag-version --force && node version.mjs",
        "patch": "npm version patch -no-git-tag-version --force && node version.mjs",
        "test": "cd lib && npm test",
        "version": "node version.mjs"
    },
    "author": "Fabien PETITJEAN <fabien.petitjean@openbraininstitute.org>",
    "license": "Apache-2.0",
    "peerDependencies": {
        "react": "^19.2.4"
    },
    "dependencies": {
        "@tolokoban/tgd": "^2.0.118",
        "fflate": "^0.8.2",
        "tslib": "^2.8.1"
    }
}
